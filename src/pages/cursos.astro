// Le cambiamos el nombre a CursosView para que no choque
import SeccionCursos from '../components/Cursos.astro';
import Notas from '../components/Notas.astro';
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <title>Cursos | SGE</title>
  </head>
  <body style="background:#13151a;color:white;font-family:system-ui;margin:0;">
    <Navigation currentPath="/cursos" />
    <main style="max-width:1100px;margin:0 auto;padding:0 1.5rem 2rem;display:grid;gap:1.5rem;">
      <!-- Usamos el nuevo nombre aquí -->
      <SeccionCursos />
      <Notas />
    </main>
  </body>
</html>