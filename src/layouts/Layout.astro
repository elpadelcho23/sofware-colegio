---
// src/layouts/Layout.astro
interface Props {
	title: string;
}
const { title } = Astro.props;

---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<title>{title}</title>
		</head>
	<body>
		<nav class="navbar">
    		<div class="logo">EscolarApp</div>
    		<div class="links">
        		<a href="/">👥 Alumnos</a>
        		<a href="/registro">Registrar Alumno</a>
        		<a href="/materias">📚 Materias</a>
        		<a href="/cursos">Cursos</a>
    		</div>
		</nav>

		<slot />

		<style is:global>
			/* Estilos para que el menú se vea siempre arriba y sea oscuro */
			.navbar {
				display: flex;
				justify-content: space-between;
				align-items: center;
				padding: 1rem 2rem;
				background: #1e2025;
				border-bottom: 1px solid #444;
			}
			.links a {
				color: white;
				text-decoration: none;
				margin-left: 1.5rem;
				font-weight: 500;
			}
			.links a:hover { color: #4dabf7; }
		</style>
	</body>
</html>