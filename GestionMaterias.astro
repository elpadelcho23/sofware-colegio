---
// src/components/GestionMaterias.astro
---

<div class="modulo-materias">
    <h2>Sección de Cátedras: "Dar Materia"</h2>
    
    <form id="form-materia" class="form-grid">
        <div class="input-group">
            <label for="materia-nombre">Nombre de la Materia</label>
            <input type="text" id="materia-nombre" placeholder="ej: Matemáticas, Programación..." required />
        </div>

        <div class="input-group">
            <label for="profesor-nombre">Profesor a cargo</label>
            <input type="text" id="profesor-nombre" placeholder="Nombre del docente" required />
        </div>
        
        <div class="seleccion-alumnos">
            <h3>Inscribir Alumnos</h3>
            <p class="hint">Seleccioná los alumnos que cursarán esta materia:</p>
            <div id="check-lista-alumnos" class="scroll-lista">
                <p class="empty-msg">Cargando alumnos disponibles...</p>
            </div>
        </div>

        <button type="submit" class="btn-crear">Registrar Materia y Alumnos</button>
    </form>

    <hr />

    <h3>Materias Registradas</h3>
    <ul id="lista-materias" class="materia-list"></ul>
</div>

<script>
    interface Materia {
        id: string;
        nombre: string;
        profesor: string;
        alumnosIds: number[];
        fechaCreacion: string;
    }

    const formMateria = document.getElementById('form-materia') as HTMLFormElement;
    const contenedorChecks = document.getElementById('check-lista-alumnos') as HTMLDivElement;
    const listaMateriasUI = document.getElementById('lista-materias') as HTMLUListElement;

    // Inicialización
    document.addEventListener('DOMContentLoaded', () => {
        renderizarSelectorAlumnos();
        mostrarMaterias();
    });

    function renderizarSelectorAlumnos() {
        const alumnos = JSON.parse(localStorage.getItem('alumnos') || '[]');
        
        if (alumnos.length === 0) {
            contenedorChecks.innerHTML = '<p class="warn">No hay alumnos registrados. Registralos en la sección de Alumnos primero.</p>';
            return;
        }

        contenedorChecks.innerHTML = alumnos.map((al: any) => `
            <label class="alumno-checkbox">
                <input type="checkbox" name="alumnos-inscritos" value="${al.id}">
                <span>${al.nombre} <small>(${al.curso})</small></span>
            </label>
        `).join('');
    }

    if (formMateria) {
        formMateria.addEventListener('submit', (e) => {
            e.preventDefault();

            const nombre = (document.getElementById('materia-nombre') as HTMLInputElement).value;
            const profesor = (document.getElementById('profesor-nombre') as HTMLInputElement).value;
            
            // Obtener IDs de alumnos seleccionados
            const checkboxes = document.querySelectorAll('input[name="alumnos-inscritos"]:checked');
            const alumnosSeleccionados = Array.from(checkboxes).map(cb => parseInt((cb as HTMLInputElement).value));

            if (alumnosSeleccionados.length === 0) {
                alert("Debes seleccionar al menos un alumno para crear la materia.");
                return;
            }

            const nuevaMateria: Materia = {
                id: crypto.randomUUID(),
                nombre,
                profesor,
                alumnosIds: alumnosSeleccionados,
                fechaCreacion: new Date().toLocaleDateString()
            };

            // Guardar en localStorage
            const materias = JSON.parse(localStorage.getItem('materias') || '[]');
            materias.push(nuevaMateria);
            localStorage.setItem('materias', JSON.stringify(materias));

            formMateria.reset();
            mostrarMaterias();
            alert(`Materia "${nombre}" creada con éxito.`);
        });
    }

    function mostrarMaterias() {
        if (!listaMateriasUI) return;
        const materias: Materia[] = JSON.parse(localStorage.getItem('materias') || '[]');
        
        listaMateriasUI.innerHTML = materias.map(m => `
            <li class="materia-card">
                <div class="materia-header">
                    <strong>${m.nombre}</strong>
                    <span>Prof: ${m.profesor}</span>
                </div>
                <div class="materia-footer">
                    <small>${m.alumnosIds.length} alumnos inscritos</small>
                </div>
            </li>
        `).reverse().join('');
    }
</script>

<style>
    .modulo-materias {
        background: #1e2025;
        padding: 1.5rem;
        border-radius: 8px;
        border: 1px solid #444;
        color: white;
    }
    .form-grid { display: grid; gap: 1.2rem; }
    .input-group { display: flex; flex-direction: column; gap: 0.5rem; }
    
    input {
        padding: 0.8rem; background: #13151a; border: 1px solid #444; color: white; border-radius: 4px;
    }

    .scroll-lista {
        max-height: 200px;
        overflow-y: auto;
        background: #13151a;
        padding: 1rem;
        border: 1px solid #333;
        border-radius: 4px;
        margin-top: 0.5rem;
    }

    .alumno-checkbox {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 0.5rem;
        border-bottom: 1px solid #222;
        cursor: pointer;
    }
    .alumno-checkbox:hover { background: #1a1d24; }
    .alumno-checkbox input { width: auto; }
    .alumno-checkbox small { color: #888; }

    .btn-crear {
        background: #51cf66;
        color: white;
        border: none;
        padding: 1rem;
        font-weight: bold;
        border-radius: 4px;
        cursor: pointer;
        transition: background 0.2s;
    }
    .btn-crear:hover { background: #40c057; }

    .materia-list { list-style: none; padding: 0; display: grid; gap: 1rem; }
    .materia-card {
        background: #13151a;
        padding: 1rem;
        border-radius: 6px;
        border-left: 4px solid #51cf66;
    }
    .materia-header { display: flex; justify-content: space-between; margin-bottom: 0.5rem; }
    .warn { color: #ff922b; font-size: 0.9rem; }
</style>